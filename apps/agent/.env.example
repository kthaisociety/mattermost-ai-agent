# Mattermost bot credentials
# Create a bot account in System Console > Integrations > Bot Accounts
MATTERMOST_BASE_URL=https://mattermost.example.com
MATTERMOST_BOT_TOKEN=

# Mastra storage (channels require persistent storage for thread state)
DATABASE_URL=file:./mastra.db

# Model providers (use whichever your agents reference)
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
VERCEL_AI_GATEWAY_KEY=

# GitHub access for the official GitHub MCP server (read-only org scanning).
# Create a fine-grained PAT at https://github.com/settings/personal-access-tokens/new
# with resource owner = kthaisociety and "Public repositories (read-only)" access.
# The token is also accepted by the remote server at https://api.githubcopilot.com/mcp/.
GITHUB_TOKEN=
GITHUB_ORG=kthaisociety
